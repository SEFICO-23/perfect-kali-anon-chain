[Unit]
Description=Kali WSL2 Plain Networking
# Run AFTER all other network services to avoid race conditions
# (networking.service and kali-firewall.service were taking eth0 down)
After=network.target networking.service systemd-networkd.service
Wants=network.target

[Service]
Type=oneshot
ExecStart=/home/%u/kali-boot-network.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
